# Copy to .env.local (gitignored) and fill in.

# Web3Forms access key for hello@bashsquad.com — get one at https://web3forms.com
# (enter the address, the key arrives by email). Public-by-design, safe to ship.
VITE_WEB3FORMS_KEY=

# Bash Squad OS lead ingest (Convex HTTP action). Leave empty until HQ is live;
# submitLead() skips the mirror when unset.
VITE_HQ_LEAD_ENDPOINT=
