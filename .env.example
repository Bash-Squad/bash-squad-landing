# Copy to .env.local (gitignored) and fill in. Everything here is server-only
# (no NEXT_PUBLIC prefix), so none of it is ever exposed to the browser.

# Email delivery — Resend (HTTP API, works on Vercel serverless). Use the SAME
# Resend account as BS-OS; a dedicated sending-only key for the site is tidier.
# Add it as a plain env var (the Vercel Resend integration is optional). Leave
# empty in dev and leads log to the server console instead of sending.
RESEND_API_KEY=

# Where lead emails land. Any mailbox — this is just a recipient, NOT routed
# through Resend, so it never touches your bashsquad.com inbox/MX.
LEAD_TO=hello@bashsquad.com

# Sender. MUST be on a domain verified in Resend. Your verified sending
# subdomain is mail.bashsquad.com (apex stays off Resend on purpose), so send
# from there — NOT from hello@bashsquad.com.
LEAD_FROM="Bash Squad <leads@mail.bashsquad.com>"

# Bash Squad OS lead ingest (Convex HTTP action). Server-to-server, so no CORS
# to configure. Leave empty until HQ is live; the action skips it when unset.
HQ_LEAD_ENDPOINT=

# Shared token for HQ lead ingest authentication (x-bs-token header). If unset,
# the mirror still POSTs but HQ will reject with 401 (or 503 on a deployment
# where the token env var isn't set). Mirror failures are best-effort and do not
# fail the lead submission — email is the system of record.
HQ_LEAD_TOKEN=
